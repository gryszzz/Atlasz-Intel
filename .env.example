# Atlasz Intel — local configuration (all optional)
#
# Atlasz is local-first and honest by default: with no configuration it runs the
# offline simulator and labels everything as "Simulated source". The flags below
# opt in to REAL data. Atlasz never presents simulated/seeded/local data as
# verified live intelligence, and it never asks for credentials it cannot use.

# --- Realtime market data -------------------------------------------------

# Enable real PUBLIC, UNAUTHENTICATED crypto WebSocket feeds (BTC/ETH).
# Off by default. When "1", the default connector becomes CoinCap public WS.
# Data is labeled "Public unauthenticated" — real, but unaudited and not advice.
# ATLASZ_ENABLE_PUBLIC_WS=1

# Force a specific connector. One of:
#   simulated            Local offline simulator (default, no network)
#   coincap_public_ws    CoinCap public crypto prices   (public, no auth)
#   binance_public_ws    Binance public trades          (public, no auth)
#   coinbase_public_ws   Coinbase public ticker         (public, no auth)
#   alpaca_iex_placeholder  Equities/ETFs — REQUIRES an API key; intentionally
#                           disabled in the default local path (fails closed).
# ATLASZ_CONNECTOR=coincap_public_ws

# Note: equities/ETF live data (Alpaca IEX) is auth-gated and not wired to any
# credential by design. Provide your own authenticated connector before relying
# on equity ticks as live data.
