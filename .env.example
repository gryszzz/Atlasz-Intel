# Atlasz Intel — local configuration (all optional)
#
# Atlasz is local-first and honest by default: with no configuration the desktop
# shell starts a public no-auth market connector (Yahoo chart + CoinGecko).
# Missing or blocked data is shown as unavailable/stale-cache, never simulated.
# Atlasz never presents public/derived/local data as verified live intelligence.

# --- Realtime market data -------------------------------------------------

# Default connector: public_market_rest
#   - Yahoo public chart endpoint for broad stocks, ETFs, indices, FX pairs,
#     sectors, and commodity futures proxies.
#   - CoinGecko public REST for mapped crypto, including KAS via kaspa.
# Data is labeled public-unauthenticated/delayed/stale-cache as appropriate.
# ATLASZ_PUBLIC_MARKET_POLL_MS=30000
# ATLASZ_YAHOO_MAX_SYMBOLS=64
# ATLASZ_YAHOO_TIMEOUT_MS=8000
# ATLASZ_COINGECKO_TIMEOUT_MS=8000

# Optional real PUBLIC, UNAUTHENTICATED crypto WebSocket feeds.
# When "1", the default connector becomes CoinCap public WS.
# ATLASZ_ENABLE_PUBLIC_WS=1

# Force a specific connector. One of:
#   public_market_rest   Broad public REST quote path (default, no auth)
#   coingecko_public_rest CoinGecko mapped crypto REST
#   coincap_public_ws    CoinCap public crypto prices   (public, no auth)
#   binance_public_ws    Binance public trades          (public, no auth)
#   coinbase_public_ws   Coinbase public ticker         (public, no auth)
#   simulated            Dev/test-only local simulator when ATLASZ_ALLOW_SIMULATED_DATA=1
#   alpaca_iex_placeholder  Equities/ETFs — REQUIRES an API key; intentionally
#                           disabled in the default local path (fails closed).
# ATLASZ_CONNECTOR=public_market_rest
# ATLASZ_ALLOW_SIMULATED_DATA=0

# Note: Yahoo chart data is public/no-auth and may be delayed, stale, rate
# limited, or unavailable. Alpaca IEX remains auth-gated and fail-closed.

# Coinbase product universe used by the public websocket connector. Invalid or
# unavailable products fail closed through websocket error/reconnect handling.
# ATLASZ_COINBASE_PRODUCTS=BTC-USD,ETH-USD,SOL-USD,LINK-USD,KAS-USD,KAS-USDT

# Local microstructure screener. Analysis-only: Atlasz never executes orders.
# Public trade feeds without Level 2 depth are transformed into a clearly labeled
# local-computed proxy; true book depth can be wired later.
# ATLASZ_MICROSTRUCTURE_BUFFER_SIZE=10000
# ATLASZ_MICROSTRUCTURE_ZSCORE=2.5

# Sampled liquidity persistence for market_ticks_daily. The raw tick stream
# remains in memory; this controls the durable bar fuel consumed by Quant Desk.
# ATLASZ_MARKET_TICK_SAMPLE_MS=1000
# ATLASZ_MARKET_TICK_MAX_PER_BATCH=96

# --- Public OSINT / world ingest -----------------------------------------

# Enable/disable the public no-auth OSINT coordinator. Enabled by default in the
# desktop shell; set to 0 for completely offline startup.
# ATLASZ_ENABLE_PUBLIC_OSINT=1

# --- Provider config + auto-discovery -------------------------------------
# Atlasz is provider-driven. Built-in public providers work out of the box;
# add your own PUBLIC providers (RSS / custom-json / GDELT adapters only) via a
# JSON file. Point ATLASZ_PROVIDER_CONFIG at it (defaults to atlasz.providers.json
# in the app data dir). Auto-discovery probes env keys + public exchange-info
# endpoints at startup and fails closed; missing keys show as missing-config.
# ATLASZ_PROVIDER_CONFIG=/absolute/path/to/atlasz.providers.json
#
# Example atlasz.providers.json entry (public URL only; no login/paywall/scrape):
# [
#   { "providerId": "custom-defense-rss", "providerName": "Defense RSS",
#     "category": "world-news", "adapter": "rss", "enabled": true,
#     "endpoint": "https://example.gov/rss", "authType": "none",
#     "provenance": "official-api" }
# ]

# Individual public loops. All are public unauthenticated and may rate-limit,
# fail, or return stale/duplicated data; Atlasz labels them accordingly.
# ATLASZ_ENABLE_RSS_RADAR=1
# ATLASZ_ENABLE_YAHOO_POLL=1
# ATLASZ_ENABLE_STOCKTWITS=1
# ATLASZ_ENABLE_POLYMARKET=1

# World Intelligence Terminal source registry. GDELT is a documented public
# unauthenticated API and is treated as evidence of public coverage, not
# verification of claims.
# ATLASZ_ENABLE_PUBLIC_WORLD=1
# ATLASZ_GDELT_POLL_MS=300000
# ATLASZ_GDELT_RATE_LIMIT_MS=20000
# ATLASZ_GDELT_TIMEOUT_MS=12000

# --- Phase 2 high-signal OSINT adapters (all fail-closed) -----------------
# Each adapter is DISABLED unless its config below is present, and the whole
# world registry also respects ATLASZ_ENABLE_PUBLIC_WORLD. Outputs carry strict
# provenance; nothing here is presented as verified.

# SEC EDGAR public filings (8-K/10-Q/10-K + amendments). provenance: public-disclosure.
# SEC requires a contactable User-Agent — fail-closed without one.
# ATLASZ_SEC_USER_AGENT=Atlasz Intel research (you@example.com)
# ATLASZ_SEC_FORM_TYPES=8-K,10-Q,10-K
# ATLASZ_SEC_INCLUDE_AMENDMENTS=1
# Optional CIK->ticker map (JSON). Unmapped filings persist as unmapped, never invented.
# ATLASZ_SEC_CIK_TICKER_MAP={"320193":"AAPL","789019":"MSFT"}
# ATLASZ_SEC_POLL_MS=600000
# ATLASZ_SEC_RATE_LIMIT_MS=60000
# ATLASZ_SEC_TIMEOUT_MS=15000

# Politician / public-official financial disclosures (DELAYED public disclosures,
# not real-time market data). provenance: public-disclosure. Configure a public
# JSON / open-civic provider URL; fail-closed without it.
# ATLASZ_POLITICIAN_DISCLOSURE_URL=https://example-public-provider/disclosures.json
# Optional extra request headers (JSON), e.g. a public API key header.
# ATLASZ_POLITICIAN_DISCLOSURE_HEADERS={"X-Api-Key":"..."}
# ATLASZ_POLITICIAN_POLL_MS=1800000

# Macro series via FRED official API. provenance: official-api. API key from
# env only; fail-closed without it. Missing observations are skipped.
# ATLASZ_FRED_API_KEY=
# ATLASZ_FRED_BASE_URL=https://api.stlouisfed.org/fred
# ATLASZ_FRED_SERIES_IDS=CPIAUCSL,UNRATE,FEDFUNDS,DGS10,GDP,PAYEMS
# ATLASZ_FRED_RATE_LIMIT_MS=1200
# ATLASZ_FRED_POLL_MS=3600000

# Treasury Fiscal Data official API. provenance: official-api. No API key.
# Debt to the Penny records are public government finance context; malformed
# rows are dropped and no fiscal values are simulated.
# ATLASZ_TREASURY_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service
# ATLASZ_TREASURY_RECORD_LIMIT=1
# ATLASZ_TREASURY_TIMEOUT_MS=15000
# ATLASZ_TREASURY_MAX_RETRIES=2
# ATLASZ_TREASURY_BACKOFF_MS=1000

# BEA official API. provenance: official-api. Requires your own free UserID
# from BEA; fail-closed without it. Source trails never persist the key.
# ATLASZ_BEA_API_KEY=
# ATLASZ_BEA_API_BASE=https://apps.bea.gov/api/data
# ATLASZ_BEA_SERIES=T10101:1
# ATLASZ_BEA_TIMEOUT_MS=20000
# ATLASZ_BEA_MAX_RETRIES=2
# ATLASZ_BEA_BACKOFF_MS=1000

# EIA official energy API. provenance: official-api. Requires your own free
# EIA Open Data API key; fail-closed without it. Source trails never persist
# api_key. First allowlist covers WTI crude, Henry Hub gas, gasoline, crude
# inventories, and U.S. electricity generation.
# ATLASZ_EIA_API_KEY=
# ATLASZ_EIA_API_BASE=https://api.eia.gov/v2
# ATLASZ_EIA_SERIES=PET.RWTC.D,NG.RNGWHHD.D,PET.EMM_EPM0_PTE_NUS_DPG.W,PET.WCESTUS1.W,ELEC.GEN.ALL-US-99.M
# ATLASZ_EIA_TIMEOUT_MS=20000
# ATLASZ_EIA_MAX_RETRIES=2
# ATLASZ_EIA_BACKOFF_MS=1000

# NOAA / National Weather Service active alerts. provenance: official-api.
# No API key, but NWS requests a descriptive User-Agent. Real alerts only:
# severity, urgency, certainty, area, and timing come from NWS, never inferred.
# ATLASZ_NWS_USER_AGENT=Atlasz-Intel (operator@example.com)
# ATLASZ_NOAA_ALERTS_URL=https://api.weather.gov/alerts/active
# ATLASZ_NOAA_MAX_RECORDS=30
# ATLASZ_NOAA_TIMEOUT_MS=20000
# ATLASZ_NOAA_MAX_RETRIES=2
# ATLASZ_NOAA_BACKOFF_MS=1000

# Poll intervals. Keep conservative defaults unless you are testing locally.
# ATLASZ_RSS_POLL_MS=30000
# ATLASZ_YAHOO_POLL_MS=60000
# ATLASZ_STOCKTWITS_POLL_MS=60000
# ATLASZ_POLYMARKET_POLL_MS=300000

# Optional local cognitive parser. Requires your own local Ollama runtime.
# Disabled by default; outputs are model-inferred, not verified.
# ATLASZ_ENABLE_OLLAMA=0
# ATLASZ_OLLAMA_ENDPOINT=http://localhost:11434/api/chat
# ATLASZ_OLLAMA_MODEL=qwen2.5:7b
# Narrative velocity thresholds determine when the parser shifts from deep
# extraction to keyword-priority and then batch-summary mode.
# ATLASZ_NARRATIVE_MEDIUM_VELOCITY=12
# ATLASZ_NARRATIVE_HIGH_VELOCITY=35
# ATLASZ_COGNITIVE_BATCH_SIZE=5
# ATLASZ_COGNITIVE_BATCH_MS=15000

# Inferred/model-generated graph edges are ephemeral: they decay by half-life
# and purge if not reinforced within the silence window.
# ATLASZ_GRAPH_EDGE_HALFLIFE_MS=21600000
# ATLASZ_GRAPH_EDGE_MAX_SILENCE_MS=86400000

# Structural placeholder only. Disabled by default and requires an environment
# token plus a future browser adapter.
# ATLASZ_ENABLE_X_EXPLORE_SCRAPER=0
# ATLASZ_X_AUTH_TOKEN=

# --- USPTO patents (PatentsView) ---------------------------------------------
# Official USPTO-funded PatentsView API. Config-gated: requires an API key (sent
# as the X-Api-Key header, never persisted). Fail-closed without it. Assignee
# organizations + classifications only — no inventor/person data.
# Get a key: https://patentsview.org/apis (search.patentsview.org)
# ATLASZ_PATENTSVIEW_API_KEY=
# Pipe-separated assignee allowlist (defaults to the curated seed companies):
# ATLASZ_PATENTSVIEW_ASSIGNEES=NVIDIA Corporation|Intel Corporation|Apple Inc.
# ATLASZ_PATENTSVIEW_LOOKBACK_DAYS=60
# ATLASZ_PATENTSVIEW_MAX_RECORDS=25

# --- Federal Register (regulatory documents) ---------------------------------
# Official FederalRegister.gov API. Public, no key required. Fail-closed on
# HTTP/schema/rate-limit failure. The govinfo PDF (legal edition) is preserved
# when present. Defaults "start narrow": curated agency allowlist + the four core
# document types (RULE, PRORULE, NOTICE, PRESDOCU).
# ATLASZ_FEDERAL_REGISTER_DISABLE=1            # opt out entirely
# Comma-separated agency SLUG override (must be real FederalRegister.gov slugs;
# invalid slugs are dropped). Empty -> curated allowlist.
# ATLASZ_FEDERAL_REGISTER_AGENCIES=securities-and-exchange-commission,treasury-department
# Comma-separated type-code override (RULE, PRORULE, NOTICE, PRESDOCU). Empty -> all four.
# ATLASZ_FEDERAL_REGISTER_TYPES=RULE,PRORULE
# ATLASZ_FEDERAL_REGISTER_LOOKBACK_DAYS=14
# ATLASZ_FEDERAL_REGISTER_MAX_RECORDS=25
