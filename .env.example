# Atlasz Intel — local configuration (all optional)
#
# Atlasz is local-first and honest by default: with no configuration the desktop
# shell starts a public no-auth market connector (Yahoo chart + CoinGecko).
# Missing or blocked data is shown as unavailable/stale-cache, never simulated.
# Atlasz never presents public/derived/local data as verified live intelligence.

# --- Realtime market data -------------------------------------------------

# Default connector: public_market_rest
#   - Yahoo public chart endpoint for broad stocks, ETFs, indices, FX pairs,
#     sectors, and commodity futures proxies.
#   - CoinGecko public REST for mapped crypto, including KAS via kaspa.
# Data is labeled public-unauthenticated/delayed/stale-cache as appropriate.
# ATLASZ_PUBLIC_MARKET_POLL_MS=30000
# ATLASZ_YAHOO_MAX_SYMBOLS=64
# ATLASZ_YAHOO_TIMEOUT_MS=8000
# ATLASZ_COINGECKO_TIMEOUT_MS=8000

# Optional real PUBLIC, UNAUTHENTICATED crypto WebSocket feeds.
# When "1", the default connector becomes CoinCap public WS.
# ATLASZ_ENABLE_PUBLIC_WS=1

# Force a specific connector. One of:
#   public_market_rest   Broad public REST quote path (default, no auth)
#   coingecko_public_rest CoinGecko mapped crypto REST
#   coincap_public_ws    CoinCap public crypto prices   (public, no auth)
#   binance_public_ws    Binance public trades          (public, no auth)
#   coinbase_public_ws   Coinbase public ticker         (public, no auth)
#   simulated            Dev/test-only local simulator when ATLASZ_ALLOW_SIMULATED_DATA=1
#   alpaca_iex_placeholder  Equities/ETFs — REQUIRES an API key; intentionally
#                           disabled in the default local path (fails closed).
# ATLASZ_CONNECTOR=public_market_rest
# ATLASZ_ALLOW_SIMULATED_DATA=0

# Note: Yahoo chart data is public/no-auth and may be delayed, stale, rate
# limited, or unavailable. Alpaca IEX remains auth-gated and fail-closed.

# Coinbase product universe used by the public websocket connector. Invalid or
# unavailable products fail closed through websocket error/reconnect handling.
# ATLASZ_COINBASE_PRODUCTS=BTC-USD,ETH-USD,SOL-USD,LINK-USD,KAS-USD,KAS-USDT

# Local microstructure screener. Analysis-only: Atlasz never executes orders.
# Public trade feeds without Level 2 depth are transformed into a clearly labeled
# local-computed proxy; true book depth can be wired later.
# ATLASZ_MICROSTRUCTURE_BUFFER_SIZE=10000
# ATLASZ_MICROSTRUCTURE_ZSCORE=2.5

# Sampled liquidity persistence for market_ticks_daily. The raw tick stream
# remains in memory; this controls the durable bar fuel consumed by Quant Desk.
# ATLASZ_MARKET_TICK_SAMPLE_MS=1000
# ATLASZ_MARKET_TICK_MAX_PER_BATCH=96

# --- Public OSINT / world ingest -----------------------------------------

# Enable/disable the public no-auth OSINT coordinator. Enabled by default in the
# desktop shell; set to 0 for completely offline startup.
# ATLASZ_ENABLE_PUBLIC_OSINT=1

# --- Provider config + auto-discovery -------------------------------------
# Atlasz is provider-driven. Built-in public providers work out of the box;
# add your own PUBLIC providers (RSS / custom-json / GDELT adapters only) via a
# JSON file. Point ATLASZ_PROVIDER_CONFIG at it (defaults to atlasz.providers.json
# in the app data dir). Auto-discovery probes env keys + public exchange-info
# endpoints at startup and fails closed; missing keys show as missing-config.
# ATLASZ_PROVIDER_CONFIG=/absolute/path/to/atlasz.providers.json
#
# Example atlasz.providers.json entry (public URL only; no login/paywall/scrape):
# [
#   { "providerId": "custom-defense-rss", "providerName": "Defense RSS",
#     "category": "world-news", "adapter": "rss", "enabled": true,
#     "endpoint": "https://example.gov/rss", "authType": "none",
#     "provenance": "official-api" }
# ]

# Individual public loops. All are public unauthenticated and may rate-limit,
# fail, or return stale/duplicated data; Atlasz labels them accordingly.
# ATLASZ_ENABLE_RSS_RADAR=1
# ATLASZ_ENABLE_YAHOO_POLL=1
# ATLASZ_ENABLE_STOCKTWITS=1
# ATLASZ_ENABLE_POLYMARKET=1

# World Intelligence Terminal source registry. GDELT DOC 2.0 is a documented
# public API (no key). It is MEDIA OBSERVATION, NOT a verified event: events render
# at the lower `media-observation` trust tier, labeled "Observed in media, not
# verified event". No causality, tone/Goldstein, or company exposure is inferred
# from headlines. Fail-closed on HTTP/non-JSON/rate-limit; honors retry/backoff.
# ATLASZ_ENABLE_PUBLIC_WORLD=1
# ATLASZ_GDELT_DISABLE=1            # opt out entirely
# Explicit query bucket (GDELT DOC query syntax; OR-joined terms). Empty -> default.
# ATLASZ_GDELT_QUERY=semiconductor OR sanctions OR tariffs
# ATLASZ_GDELT_TIMESPAN=1d         # lookback window (e.g. 6h, 1d, 3d)
# ATLASZ_GDELT_MAX_RECORDS=50
# ATLASZ_GDELT_TIMEOUT_MS=15000
# ATLASZ_GDELT_MAX_RETRIES=1
# ATLASZ_GDELT_BACKOFF_MS=1000

# --- Phase 2 high-signal OSINT adapters (all fail-closed) -----------------
# Each adapter is DISABLED unless its config below is present, and the whole
# world registry also respects ATLASZ_ENABLE_PUBLIC_WORLD. Outputs carry strict
# provenance; nothing here is presented as verified.

# SEC EDGAR public filings (8-K/10-Q/10-K + amendments). provenance: public-disclosure.
# SEC requires a contactable User-Agent — fail-closed without one.
# ATLASZ_SEC_USER_AGENT=Atlasz Intel research (you@example.com)
# ATLASZ_SEC_FORM_TYPES=8-K,10-Q,10-K
# ATLASZ_SEC_INCLUDE_AMENDMENTS=1
# Optional CIK->ticker map (JSON). Unmapped filings persist as unmapped, never invented.
# ATLASZ_SEC_CIK_TICKER_MAP={"320193":"AAPL","789019":"MSFT"}
# ATLASZ_SEC_POLL_MS=600000
# ATLASZ_SEC_RATE_LIMIT_MS=60000
# ATLASZ_SEC_TIMEOUT_MS=15000

# Market Reference Master via SEC company_tickers.json. provenance: official-api.
# Public no-auth identity spine: ticker <-> CIK <-> legal title only. No
# exchange, sector, industry, ETF weights, prices, or fuzzy merge are inferred.
# ATLASZ_MARKET_REFERENCE_DISABLE=1
# ATLASZ_SEC_COMPANY_TICKERS_URL=https://www.sec.gov/files/company_tickers.json
# ATLASZ_SEC_COMPANY_TICKERS_USER_AGENT=Atlasz Intel market reference (you@example.com)
# ATLASZ_MARKET_REFERENCE_STALE_AFTER_MS=604800000
# ATLASZ_MARKET_REFERENCE_MAX_RECORDS=25000

# --- SEC Company Facts (XBRL fundamentals) -----------------------------------
# Official SEC companyfacts API. Public but REQUIRES a descriptive contactable
# User-Agent (reuses ATLASZ_SEC_USER_AGENT); fail-closed without it. CIKs come from
# the Market Reference Master identity spine. Historical reported facts only — no
# estimates, valuation, AI interpretation, or trading signal. Bounded ticker
# allowlist; one latest fact per concept (Revenue, Net income, Assets, Liabilities,
# Cash, Capex, Shares outstanding).
# ATLASZ_SEC_FACTS_DISABLE=1
# Comma-separated ticker allowlist (default: NVDA,AMD,AAPL,MSFT,AMZN,GOOGL,META,TSLA,INTC,XOM,CVX):
# ATLASZ_SEC_FACTS_TICKERS=NVDA,AMD,AAPL
# ATLASZ_SEC_FACTS_STALE_DAYS=100
# ATLASZ_SEC_FACTS_TIMEOUT_MS=25000

# --- SEC Form 4 (insider transactions) ---------------------------------------
# Official SEC Form 4 ownership filings. Public but REQUIRES a descriptive
# contactable User-Agent (reuses ATLASZ_SEC_USER_AGENT); fail-closed without it.
# Issuer CIKs come from the Market Reference Master identity spine. Source-reported
# transaction evidence only — no sentiment (bullish/bearish), valuation, price
# prediction, or trading advice; reporting-owner data limited to source-published
# name/title. Non-derivative transactions only in this slice. Official SEC hosts only.
# ATLASZ_SEC_FORM4_DISABLE=1
# Comma-separated ticker allowlist (default: NVDA,AMD,AAPL,MSFT,AMZN,GOOGL,META,TSLA,INTC,XOM,CVX):
# ATLASZ_SEC_FORM4_TICKERS=NVDA,AMD,AAPL
# ATLASZ_SEC_FORM4_PER_COMPANY=5
# ATLASZ_SEC_FORM4_TIMEOUT_MS=20000

# --- SEC Form 13F (institutional holdings) -----------------------------------
# Official SEC Form 13F-HR / 13F-HR/A information-table XML. Public but REQUIRES
# a descriptive contactable User-Agent (reuses ATLASZ_SEC_USER_AGENT); fail-closed
# without it. Bounded institutional-manager CIK allowlist. Quarterly DELAYED
# reported holding snapshot only — not current position, conviction, performance,
# valuation, price prediction, or trading advice. Issuer exposure only when an
# exact curated CUSIP->ticker mapping exists.
# ATLASZ_SEC_13F_DISABLE=1
# Comma-separated manager CIK allowlist (default: Berkshire, BlackRock, Vanguard,
# State Street, Citadel, Jane Street, Renaissance Technologies, ARK):
# ATLASZ_SEC_13F_CIKS=1067983,1364742,102909
# ATLASZ_SEC_13F_PER_MANAGER=1
# ATLASZ_SEC_13F_MAX_HOLDINGS=50
# ATLASZ_SEC_13F_TIMEOUT_MS=25000

# Politician / public-official financial disclosures (DELAYED public disclosures,
# not real-time market data). provenance: public-disclosure. Configure a public
# JSON / open-civic provider URL; fail-closed without it.
# ATLASZ_POLITICIAN_DISCLOSURE_URL=https://example-public-provider/disclosures.json
# Optional extra request headers (JSON), e.g. a public API key header.
# ATLASZ_POLITICIAN_DISCLOSURE_HEADERS={"X-Api-Key":"..."}
# ATLASZ_POLITICIAN_POLL_MS=1800000

# Macro series via FRED. provenance: official-api. Public FRED graph CSV runs
# without a key; optional API key upgrades to REST metadata. Missing observations
# are skipped.
# ATLASZ_FRED_API_KEY=
# ATLASZ_FRED_BASE_URL=https://api.stlouisfed.org/fred
# ATLASZ_FRED_SERIES_IDS=CPIAUCSL,UNRATE,FEDFUNDS,DGS10,GDP,PAYEMS
# ATLASZ_FRED_RATE_LIMIT_MS=1200
# ATLASZ_FRED_POLL_MS=3600000

# Treasury Fiscal Data official API. provenance: official-api. No API key.
# Debt to the Penny records are public government finance context; malformed
# rows are dropped and no fiscal values are simulated.
# ATLASZ_TREASURY_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service
# ATLASZ_TREASURY_RECORD_LIMIT=1
# ATLASZ_TREASURY_TIMEOUT_MS=15000
# ATLASZ_TREASURY_MAX_RETRIES=2
# ATLASZ_TREASURY_BACKOFF_MS=1000

# BEA official API. provenance: official-api. Requires your own free UserID
# from BEA; fail-closed without it. Source trails never persist the key.
# ATLASZ_BEA_API_KEY=
# ATLASZ_BEA_API_BASE=https://apps.bea.gov/api/data
# ATLASZ_BEA_SERIES=T10101:1
# ATLASZ_BEA_TIMEOUT_MS=20000
# ATLASZ_BEA_MAX_RETRIES=2
# ATLASZ_BEA_BACKOFF_MS=1000

# EIA official energy API. provenance: official-api. Requires your own free
# EIA Open Data API key; fail-closed without it. Source trails never persist
# api_key. First allowlist covers WTI crude, Henry Hub gas, gasoline, crude
# inventories, and U.S. electricity generation.
# ATLASZ_EIA_API_KEY=
# ATLASZ_EIA_API_BASE=https://api.eia.gov/v2
# ATLASZ_EIA_SERIES=PET.RWTC.D,NG.RNGWHHD.D,PET.EMM_EPM0_PTE_NUS_DPG.W,PET.WCESTUS1.W,ELEC.GEN.ALL-US-99.M
# ATLASZ_EIA_TIMEOUT_MS=20000
# ATLASZ_EIA_MAX_RETRIES=2
# ATLASZ_EIA_BACKOFF_MS=1000

# EIA public bulk baseline. provenance: official-api. No API key required, but
# this is a bounded bulk-reference subset only — not full EIA API coverage and
# not a replacement for ATLASZ_EIA_API_KEY/facility/grid connectors.
# ATLASZ_EIA_BULK_DISABLE=0
# ATLASZ_EIA_BULK_SERIES=PET.RWTC.D,NG.RNGWHHD.D,PET.EMM_EPM0_PTE_NUS_DPG.W,PET.WCESTUS1.W,ELEC.GEN.ALL-US-99.M
# ATLASZ_EIA_BULK_INCLUDE_ELEC=1
# ATLASZ_EIA_BULK_MAX_RECORDS=5
# ATLASZ_EIA_BULK_MAX_LINES=750000
# ATLASZ_EIA_BULK_MAX_COMPRESSED_BYTES=100663296

# EIA power-plant facility inventory (EIA-860M operating-generator-capacity).
# provenance: official-api. Reuses ATLASZ_EIA_API_KEY; fail-closed without it.
# Location CONTEXT only — never an outage/disruption/vulnerability claim.
# Optional 2-letter state allowlist keeps the slice narrow. Coordinates are
# emitted only when the source provides them (else region-only/unknown).
# ATLASZ_EIA_FACILITIES_DISABLE=0
# ATLASZ_EIA_FACILITY_STATES=TX,CA
# ATLASZ_EIA_FACILITY_MAX=200

# EIA petroleum refineries (U.S. Energy Atlas Petroleum Refineries / EIA-820).
# provenance: official-api. Public GeoJSON, no key. Location/capacity context
# only — never an outage/disruption/vulnerability claim. Override the data URL
# only with an EIA or ArcGIS refinery FeatureServer (validated).
# ATLASZ_EIA_REFINERIES_DISABLE=0
# ATLASZ_EIA_REFINERIES_URL=
# ATLASZ_EIA_REFINERY_MAX=200

# LNG import/export terminals. provenance: official-api. FAIL-CLOSED by design:
# inert until you pin a CONFIRMED official source endpoint. No default URL.
# Location/capacity context only — never an outage/disruption/export-flow claim.
# Accepted hosts: eia.gov / ferc.gov / energy.gov, or the confirmed EIA Atlas
# LNG ArcGIS service (Lng_ImportExportTerminals_US_EIA). Confirmed sources:
#   EIA Atlas dataset: https://atlas.eia.gov/datasets/liquefied-natural-gas-lng-import-and-export-terminals
#   EIA ArcGIS service: https://services7.arcgis.com/FGr1D95XCGALKXqM/arcgis/rest/services/Lng_ImportExportTerminals_US_EIA/FeatureServer
#   FERC LNG page:      https://www.ferc.gov/natural-gas/lng
# (The EIA FeatureServer query may require an ArcGIS token / use the Atlas GeoJSON export.)
# ATLASZ_LNG_TERMINALS_URL=
# ATLASZ_LNG_TERMINAL_MAX=200

# Nuclear plants — LAYER 1 (EIA, geospatial). Reuses the EIA generator inventory
# (EIA-860M) filtered to nuclear fuel; needs ATLASZ_EIA_API_KEY (same key as the
# power-plant slice). Facility/location/capacity context only — never a safety/
# outage/emergency claim.
# ATLASZ_EIA_NUCLEAR_DISABLE=0

# Nuclear plants — LAYER 2 (NRC, regulatory status). Official public NRC Power
# Reactor Status Report (nrc.gov, no key). Reports operating power level per unit
# as the regulator publishes it — never an Atlasz safety/outage assessment. Kept
# separate from the EIA layer (no fuzzy merge).
# ATLASZ_NRC_REACTOR_STATUS_DISABLE=0
# ATLASZ_NRC_REACTOR_STATUS_URL=https://www.nrc.gov/reading-rm/doc-collections/event-status/reactor-status/PowerReactorStatusForLast365Days.txt
# ATLASZ_NRC_REACTOR_STATUS_MAX=200

# Balancing authorities / grid regions. provenance: official-api. Official EIA
# respondent facet (electricity/rto) — the U.S. balancing-authority reference
# list. Reuses ATLASZ_EIA_API_KEY; fail-closed without it. Grid-context reference
# only — never an outage/grid-stress/reliability/vulnerability claim. The
# power-plant -> BA link rides on the BA code already on EIA plant records.
# ATLASZ_EIA_BA_DISABLE=0
# ATLASZ_EIA_BA_MAX=200

# Ports / UN/LOCODE (UNECE official trade/location code registry). provenance:
# official-api. Public UNECE/UNICC package runs by default; optional
# ATLASZ_UNLOCODE_URL can pin another official CSV/package. Location-code
# registry only — never live port activity, vessel traffic, congestion, or
# disruption. Coordinates only when the source row provides them; physical port
# geometry is a later World Port Index enrichment. Set PORTS_ONLY=0 to include
# rail/road/airport/logistics codes.
# Source/download: https://unece.org/trade/cefact/UNLOCODE-Download
# ATLASZ_UNLOCODE_DISABLE=0
# ATLASZ_UNLOCODE_URL=
# ATLASZ_UNLOCODE_PORTS_ONLY=1
# ATLASZ_UNLOCODE_MAX=500

# World Port Index (NGA Pub 150) — physical port enrichment (Layer 2 of ports).
# provenance: official-api. Public NGA CSV (no key). Physical reference only —
# never live traffic, congestion, trade volume, or disruption. Links to UN/LOCODE
# only on an exact source-field code match. Default CSV key may change per WPI
# edition (override via ATLASZ_WPI_URL; nga.mil host required). Source/download:
# https://msi.nga.mil/Publications/WPI
# ATLASZ_WPI_DISABLE=0
# ATLASZ_WPI_URL=
# ATLASZ_WPI_MAX=800

# USGS minerals / mines (materials reference layer). provenance: official-api.
# Two-source-aware: MRDS public CSV runs by default as legacy reference; optional
# USMIN/MRDS official URLs can override/add sources. MRDS is NOT updated since
# 2011 — never shown as current activity. Reference only — never current
# production, reserves, ownership, or investment signal.
# Sources: https://mrdata.usgs.gov/mrds/  and  https://mrdata.usgs.gov/usmin/
# ATLASZ_USGS_MINERALS_DISABLE=0
# ATLASZ_USGS_USMIN_URL=
# ATLASZ_USGS_MRDS_URL=
# ATLASZ_USGS_MINERALS_MAX=600

# Realtime equity/ETF quotes (key-gated, fail-closed). provenance: auth-gated.
# No seeded/default/random-walk price ever renders as real — without keys the UI
# shows PRICE_UNAVAILABLE. Keys travel only in request headers, never persisted.
# Not trading advice, prediction, or a signal score.
# ATLASZ_EQUITY_QUOTE_PROVIDER=alpaca
# ATLASZ_ALPACA_API_KEY=
# ATLASZ_ALPACA_SECRET_KEY=
# ATLASZ_ALPACA_DATA_BASE=https://data.alpaca.markets/v2

# Options chain / open interest (key-gated, fail-closed). Reuses the Alpaca keys
# above + an underlyings allowlist. Open interest shown only when source-provided;
# no flow/unusual-activity inference, no trading advice or signal score.
# ATLASZ_OPTIONS_PROVIDER=alpaca
# ATLASZ_OPTIONS_UNDERLYINGS=AAPL,MSFT,SPY,NVDA
# ATLASZ_OPTIONS_MAX=200

# NOAA / National Weather Service active alerts. provenance: official-api.
# No API key, but NWS requests a descriptive User-Agent. Real alerts only:
# severity, urgency, certainty, area, and timing come from NWS, never inferred.
# ATLASZ_NWS_USER_AGENT=Atlasz-Intel (operator@example.com)
# ATLASZ_NOAA_ALERTS_URL=https://api.weather.gov/alerts/active
# ATLASZ_NOAA_MAX_RECORDS=30
# ATLASZ_NOAA_TIMEOUT_MS=20000
# ATLASZ_NOAA_MAX_RETRIES=2
# ATLASZ_NOAA_BACKOFF_MS=1000

# Poll intervals. Keep conservative defaults unless you are testing locally.
# ATLASZ_RSS_POLL_MS=30000
# ATLASZ_YAHOO_POLL_MS=60000
# ATLASZ_STOCKTWITS_POLL_MS=60000
# ATLASZ_POLYMARKET_POLL_MS=300000

# Optional local cognitive parser. Requires your own local Ollama runtime.
# Disabled by default; outputs are model-inferred, not verified.
# ATLASZ_ENABLE_OLLAMA=0
# ATLASZ_OLLAMA_ENDPOINT=http://localhost:11434/api/chat
# ATLASZ_OLLAMA_MODEL=qwen2.5:7b
# Narrative velocity thresholds determine when the parser shifts from deep
# extraction to keyword-priority and then batch-summary mode.
# ATLASZ_NARRATIVE_MEDIUM_VELOCITY=12
# ATLASZ_NARRATIVE_HIGH_VELOCITY=35
# ATLASZ_COGNITIVE_BATCH_SIZE=5
# ATLASZ_COGNITIVE_BATCH_MS=15000

# Inferred/model-generated graph edges are ephemeral: they decay by half-life
# and purge if not reinforced within the silence window.
# ATLASZ_GRAPH_EDGE_HALFLIFE_MS=21600000
# ATLASZ_GRAPH_EDGE_MAX_SILENCE_MS=86400000

# Structural placeholder only. Disabled by default and requires an environment
# token plus a future browser adapter.
# ATLASZ_ENABLE_X_EXPLORE_SCRAPER=0
# ATLASZ_X_AUTH_TOKEN=

# --- USPTO patents (PatentsView) ---------------------------------------------
# Official USPTO-funded PatentsView API. Config-gated: requires an API key (sent
# as the X-Api-Key header, never persisted). Fail-closed without it. Assignee
# organizations + classifications only — no inventor/person data.
# Get a key: https://patentsview.org/apis (search.patentsview.org)
# ATLASZ_PATENTSVIEW_API_KEY=
# Pipe-separated assignee allowlist (defaults to the curated seed companies):
# ATLASZ_PATENTSVIEW_ASSIGNEES=NVIDIA Corporation|Intel Corporation|Apple Inc.
# ATLASZ_PATENTSVIEW_LOOKBACK_DAYS=60
# ATLASZ_PATENTSVIEW_MAX_RECORDS=25

# --- Federal Register (regulatory documents) ---------------------------------
# Official FederalRegister.gov API. Public, no key required. Fail-closed on
# HTTP/schema/rate-limit failure. The govinfo PDF (legal edition) is preserved
# when present. Defaults "start narrow": curated agency allowlist + the four core
# document types (RULE, PRORULE, NOTICE, PRESDOCU).
# ATLASZ_FEDERAL_REGISTER_DISABLE=1            # opt out entirely
# Comma-separated agency SLUG override (must be real FederalRegister.gov slugs;
# invalid slugs are dropped). Empty -> curated allowlist.
# ATLASZ_FEDERAL_REGISTER_AGENCIES=securities-and-exchange-commission,treasury-department
# Comma-separated type-code override (RULE, PRORULE, NOTICE, PRESDOCU). Empty -> all four.
# ATLASZ_FEDERAL_REGISTER_TYPES=RULE,PRORULE
# ATLASZ_FEDERAL_REGISTER_LOOKBACK_DAYS=14
# ATLASZ_FEDERAL_REGISTER_MAX_RECORDS=25

# --- Congress.gov legislation ------------------------------------------------
# Official Congress.gov API v3. Public DEMO_KEY mode runs by default. Optional
# ATLASZ_CONGRESS_API_KEY raises quota only; api_key is stripped from every
# persisted/displayed URL. Bill/action metadata only; no political or company
# exposure inference.
# ATLASZ_CONGRESS_API_KEY=
# ATLASZ_CONGRESS_BILL_URL=https://api.congress.gov/v3/bill
# ATLASZ_CONGRESS_MAX_RECORDS=20
# ATLASZ_CONGRESS_TIMEOUT_MS=20000
# ATLASZ_CONGRESS_MAX_RETRIES=1
# ATLASZ_CONGRESS_BACKOFF_MS=1000

# --- OFAC SDN sanctions -------------------------------------------------------
# Official Treasury OFAC SDN export. Public, no key. The endpoint 302-redirects to
# a presigned S3 URL; only the clean Treasury sourceDataUrl is ever persisted.
# Fail-closed on HTTP/schema/rate-limit failure; honors 429/Retry-After with
# bounded retry/backoff (shared fetch path, like the other gov connectors).
# ATLASZ_OFAC_DISABLE=1            # opt out entirely
# ATLASZ_OFAC_MAX_RECORDS=40
# ATLASZ_OFAC_TIMEOUT_MS=30000
# ATLASZ_OFAC_MAX_RETRIES=1
# ATLASZ_OFAC_BACKOFF_MS=1000

# --- UN Comtrade (catalog-driven trade flows) --------------------------------
# Official UN Comtrade data API. Requires a subscription key; fail-closed without
# it. The key travels ONLY in the Ocp-Apim-Subscription-Key header — never in a
# URL or persisted field. Commodity coverage is discovered from the public
# reference catalog (all commodities); pulls are BOUNDED (batchSize x
# maxRequestsPerRun per run) with checkpoint/resume — no full-world ingestion.
# Country/partner/commodity trade-flow evidence only; no company-level claims.
# ATLASZ_UN_COMTRADE_API_KEY=
# ATLASZ_UN_COMTRADE_DISABLE=1          # opt out entirely
# ATLASZ_UN_COMTRADE_REPORTER=842       # single reporter (e.g. 842 = USA); bounded
# ATLASZ_UN_COMTRADE_PARTNER=0          # 0 = World
# ATLASZ_UN_COMTRADE_FLOW=M,X           # M=import, X=export
# ATLASZ_UN_COMTRADE_PERIOD=2024        # year (annual) or YYYYMM (monthly)
# ATLASZ_UN_COMTRADE_FREQ=A             # A=annual, M=monthly
# ATLASZ_UN_COMTRADE_CLASSIFICATION=HS  # HS, H6, …
# ATLASZ_UN_COMTRADE_COMMODITY_LEVEL=6  # restrict to a digit level (optional)
# ATLASZ_UN_COMTRADE_BATCH_SIZE=50      # commodity codes per request (<=100)
# ATLASZ_UN_COMTRADE_MAX_REQUESTS=5     # batches per run (bounded; resumes next run)

# --- OpenAlex research metadata ---------------------------------------------
# Official OpenAlex Works API. Public no-key mode runs by default. Optional
# ATLASZ_OPENALEX_API_KEY raises quota only; api_key is stripped from every
# persisted/displayed URL. Metadata only: not validation of technical claims,
# breakthroughs, or market impact.
# ATLASZ_OPENALEX_API_KEY=
# ATLASZ_OPENALEX_API_BASE=https://api.openalex.org/works
# ATLASZ_OPENALEX_TOPICS=semiconductors,EUV lithography,AI accelerators,silicon photonics,batteries,grid storage,nuclear energy,LNG,cybersecurity,supply chain
# ATLASZ_OPENALEX_PER_BUCKET=10
# ATLASZ_OPENALEX_LOOKBACK_DAYS=30
# ATLASZ_OPENALEX_MAX_AUTHORS=4
# ATLASZ_OPENALEX_TIMEOUT_MS=20000
# ATLASZ_OPENALEX_MAX_RETRIES=1
# ATLASZ_OPENALEX_BACKOFF_MS=1000

# --- Crossref DOI metadata ---------------------------------------------------
# Official Crossref REST API. No key required. Optional mailto uses the polite
# pool on requests and is stripped from every persisted/displayed URL. Metadata
# only: no full-text scraping, claim validation, citation-quality claim, or
# market inference.
# ATLASZ_CROSSREF_MAILTO=operator@example.com
# ATLASZ_CROSSREF_API_BASE=https://api.crossref.org/works
# ATLASZ_CROSSREF_TOPICS=semiconductors,AI accelerators,batteries,cybersecurity,supply chain
# ATLASZ_CROSSREF_ROWS=5
# ATLASZ_CROSSREF_LOOKBACK_DAYS=60
# ATLASZ_CROSSREF_TIMEOUT_MS=20000
# ATLASZ_CROSSREF_MAX_RETRIES=1
# ATLASZ_CROSSREF_BACKOFF_MS=1000
